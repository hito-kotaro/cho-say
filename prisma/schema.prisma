generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  description String   @default("") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  dates     EventDate[]
  responses Response[]
  shopVotes ShopVote[]

  @@map("events")
}

model EventDate {
  id      String   @id @default(uuid()) @db.Uuid
  eventId String   @map("event_id") @db.Uuid
  date    DateTime @db.Timestamp()

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, date])
  @@index([eventId])
  @@map("event_dates")
}

model Response {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  event        Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  availability ResponseAvailability[]

  @@index([eventId])
  @@map("responses")
}

model ResponseAvailability {
  id         String @id @default(uuid()) @db.Uuid
  responseId String @map("response_id") @db.Uuid
  date       String @db.VarChar(20)
  answer     String @db.VarChar(5)

  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([responseId, date])
  @@index([responseId])
  @@map("response_availability")
}

model Area {
  id   String @id @db.VarChar(50)
  name String @db.VarChar(100)

  shops Shop[]

  @@map("areas")
}

model Shop {
  id             String   @id @db.VarChar(100)
  name           String   @db.VarChar(200)
  areaId         String   @map("area_id") @db.VarChar(50)
  genre          String   @db.VarChar(100)
  budget         String   @db.VarChar(100)
  address        String   @db.VarChar(500)
  url            String?  @db.Text
  imageUrl       String?  @map("image_url") @db.Text
  externalId     String?  @map("external_id") @db.VarChar(200)
  externalSource String?  @map("external_source") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  area  Area       @relation(fields: [areaId], references: [id])
  votes ShopVote[]

  @@unique([externalSource, externalId])
  @@index([areaId])
  @@map("shops")
}

model ShopVote {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid
  shopId  String @map("shop_id") @db.VarChar(100)
  count   Int    @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  shop  Shop  @relation(fields: [shopId], references: [id])

  @@unique([eventId, shopId])
  @@index([eventId])
  @@map("shop_votes")
}
